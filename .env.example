# Optional incoming API authentication for this proxy
# If set, clients must send:
# - Authorization: Bearer <key>
#   or
# - x-api-key: <key>
COPILOT_API_KEY=your_api_key_here

# Optional proxy settings (used when starting with --proxy-env).
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
